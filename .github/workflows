name: Extract Zip Uploads

on:
  push:
    paths:
      - 'uploads/**/*.zip'  # Triggers only on zip files in the 'uploads' folder
  workflow_dispatch:        # Allows manual triggering from the Actions tab

jobs:
  unzip:
    runs-on: ubuntu-latest
    permissions:
      contents: write       # Grants permission to push changes back to the repo

    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4

      - name: Extract and Commit
        run: |
          # Navigate to the folder containing the zip (optional, adjust if needed)
          cd uploads 
          
          # Safety: Remove previous extracted content if it exists
          rm -rf extracted_content || true
          
          # Identify the zip file name
          filename=$(basename -s .zip *.zip)
          
          # Create a temp directory for extraction
          mkdir extracted_content
          unzip *.zip -d extracted_content
          
          # Remove the original zip file
          rm *.zip
          
          # Move contents up if they are nested (adjust 'temp' logic if your zip structure varies)
          # If your zip extracts directly to files, you can skip moving from a subfolder
          # This example assumes files might be in a subfolder inside the zip
          if [ -d "extracted_content/$filename" ]; then
            mv extracted_content/$filename/* extracted_content/
            rm -rf extracted_content/$filename
          fi
          
          # Configure Git user
          git config --local user.email "github-actions[bot]@users.noreply.github.com"
          git config --local user.name "github-actions[bot]"
          
          # Stage, Commit, and Push
          git add .
          git commit -m "Auto-extract: $filename"
          git push
